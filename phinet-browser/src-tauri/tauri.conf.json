{
  "productName": "PhiNet Browser",
  "version": "0.1.0",
  "identifier": "network.phinet.com",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon_32x32.png",
      "icons/icon_128x128.png",
      "icons/icon_256x256.png",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/phinet-daemon"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "\u03a6NET",
        "width": 1180,
        "height": 820,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; frame-src https: http: data:; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://localhost:*"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}