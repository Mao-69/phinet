{
  "productName": "PHINET Browser",
  "version": "0.1.0",
  "identifier": "network.phinet.browser",
  "build": {
    "frontendDist":      "../dist",
    "devUrl":            "http://localhost:1420",
    "beforeDevCommand":  "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon_32x32.png",
      "icons/icon_128x128.png",
      "icons/icon_256x256.png",
      "icons/icon.png"
    ]
  },
  "app": {
    "windows": [
      {
        "title":         "PHINET Browser",
        "width":         1280,
        "height":        820,
        "minWidth":      900,
        "minHeight":     600,
        "resizable":     true,
        "fullscreen":    false,
        "decorations":   true,
        "transparent":   false,
        "center":        true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: http://localhost:*; connect-src 'self' http://localhost:* ws://localhost:*"
    }
  },
  "plugins": {
    "shell": { "open": true },
    "dialog": null
  }
}
